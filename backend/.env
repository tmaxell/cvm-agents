# ── LLM ──────────────────────────────────────────────────────────────────────
# Варианты: groq | gemini | ollama | anthropic | gigachat
LLM_PROVIDER=groq

# ── Groq (FREE tier, recommended) ────────────────────────────────────────────
GROQ_API_KEY=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
# Модели (баланс качество/скорость):
#   llama-3.3-70b-versatile  — лучшее качество tool use (по умолчанию)
#   llama-3.1-8b-instant     — быстрее и дешевле, tool use чуть слабее
#   llama-3.1-70b-versatile  — альтернатива 70b
# llama-3.1-8b-instant: 20000 TPM (vs 12000 for 70b) — fits our prompt+tools budget
# llama-3.3-70b-versatile: better reasoning but hits free-tier token limit
GROQ_MODEL=llama-3.3-70b-versatile

#LLM_PROVIDER=anthropic
#ANTHROPIC_API_KEY=sk-ant-...

# ── GigaChat ─────────────────────────────────────────────────────────────────
GIGACHAT_AUTH_KEY=MDE5OWRjOTUtOGE2YS03ZjAyLWExOGQtOWZlYWU0MGNlNDViOjZiM2UxMDMzLTVlZDYtNGU4NS04ZGE0LTU0YjYxMzE4MjBlMQ==
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_CHAT_MODEL=GigaChat
GIGACHAT_EMBEDDING_MODEL=Embeddings
GIGACHAT_USE_LOCAL_EMBEDDINGS=true
