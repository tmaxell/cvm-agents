# Скопируй в backend/.env и заполни ключи.
# backend/.env находится в .gitignore — НЕ коммитить, ключи не должны попадать в git.

# ── LLM провайдер ─────────────────────────────────────────────────────────────
# Варианты: gemini | groq | gigachat | ollama | anthropic
LLM_PROVIDER=gemini

# ── Google Gemini (рекомендован — самый щедрый free tier) ────────────────────
# Ключ: https://aistudio.google.com → Get API key → Create API key
# Free tier (май 2026):
#   gemini-2.5-flash       — 10 RPM / 250 RPD / 250k TPM  (баланс качество/лимит, по умолчанию)
#   gemini-2.5-flash-lite  — 15 RPM / 1000 RPD / 250k TPM (если упираемся в RPD)
#   gemini-2.5-pro         —  5 RPM / 100 RPD / 250k TPM  (для сложных задач)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# ── Groq (FREE tier, альтернатива) ───────────────────────────────────────────
# Ключ: https://console.groq.com → API Keys
# llama-3.3-70b — лучшее качество tool use, но низкий TPD на free tier
# llama-3.1-8b-instant — быстрее и с большим TPD
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=2048

# ── GigaChat (Sber, FREE для физ.лиц) ────────────────────────────────────────
# Ключ: https://developers.sber.ru/portal/products/gigachat
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_CHAT_MODEL=GigaChat
GIGACHAT_TOOL_MODEL=GigaChat
GIGACHAT_EMBEDDING_MODEL=Embeddings
GIGACHAT_USE_LOCAL_EMBEDDINGS=true
GIGACHAT_ALLOW_INSECURE_TLS=true

# ── Ollama (полностью локально, без ключей) ──────────────────────────────────
# brew install ollama && ollama pull qwen2.5:7b && ollama serve
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic Claude (платный) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Embeddings (local — без API-ключа, all-MiniLM-L6-v2) ────────────────────
EMBEDDING_PROVIDER=local

# ── AdTarget API ──────────────────────────────────────────────────────────────
ADTARGET_API_BASE=http://192.168.15.102:4001
ADTARGET_TOKEN_URL=http://192.168.15.102:8117/auth/realms/mmp/protocol/openid-connect/token
ADTARGET_CLIENT_ID=adtarget
ADTARGET_USERNAME=
ADTARGET_PASSWORD=
# true — mock без VPN (фейковые данные); false — реальный API
ADTARGET_MOCK=true
