# ── AdTarget API ──────────────────────────────────────────────────────────────
ADTARGET_API_BASE=http://192.168.15.102:4001
ADTARGET_TOKEN_URL=http://192.168.15.102:8117/auth/realms/mmp/protocol/openid-connect/token
ADTARGET_CLIENT_ID=adtarget
ADTARGET_USERNAME=your_login@company.com
ADTARGET_PASSWORD=your_password

# ── LLM Provider ──────────────────────────────────────────────────────────────
# auto (по умолчанию): если есть ANTHROPIC_API_KEY — anthropic, иначе gigachat
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=gigachat

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── GigaChat (Sber) ───────────────────────────────────────────────────────────
# GIGACHAT_AUTH_KEY=<base64 client_id:client_secret>
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_CHAT_MODEL=GigaChat
# GIGACHAT_TOOL_MODEL=GigaChat-Pro      # для F2 Campaign Builder (нужен tool use)
# GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# GIGACHAT_ALLOW_INSECURE_TLS=true      # если сертификат Sber не валидируется

# ── Groq (рекомендуется для прототипа) ────────────────────────────────────────
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=2048
#
# Campaign Builder: лимиты контекста (413 от Groq при переполнении)
# BUILDER_MESSAGE_TOKEN_BUDGET=26000
# BUILDER_MAX_TARGET_GROUPS=150
# BUILDER_MAX_CHANNELS=200
# BUILDER_MAX_EVENTS=400
# BUILDER_MAX_OFFERS=300

# ── Embeddings ────────────────────────────────────────────────────────────────
# auto: если есть ANTHROPIC_API_KEY — voyage-3-lite, иначе local HuggingFace
# EMBEDDING_PROVIDER=anthropic
# EMBEDDING_PROVIDER=local
